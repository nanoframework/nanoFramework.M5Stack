    <repository type="git" url="https://github.com/nanoframework/nanoFramework.M5Stack" commit="$commit$" />
    <copyright>Copyright (c) .NET Foundation and Contributors</copyright>
    <description>This package includes the nanoFramework.AtomMatrix assembly for .NET nanoFramework C# projects.</description>
    <tags>nanoFramework C# csharp netmf netnf m5stack AtomMatrix</tags>
    <dependencies>
     <group targetFramework=".NETnanoFramework1.0">
      <dependency id="nanoFramework.CoreLibrary" version="2.0.0-preview.35" />
      <dependency id="nanoFramework.Hardware.Esp32" version="2.0.0-preview.7" />
