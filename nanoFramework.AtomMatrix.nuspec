      <dependency id="nanoFramework.System.Device.Dac" version="2.0.0-preview.1" />
      <dependency id="nanoFramework.System.Device.Spi" version="2.0.0-preview.9" />
      <dependency id="nanoFramework.Iot.Device.Ws28xx.Esp32" version="2.0.0-preview.18" />

    </group>
    </dependencies>
  </metadata>
  <files>
    <file src="nanoFramework.AtomMatrix\bin\Release\nanoFramework.AtomMatrix.*" target="lib\netnano1.0" />
    <file src="assets\readme.txt" target="" />
